# vllm 服务配置示例文件
# 复制此文件为 .env 并修改配置

# 模型路径（必需）
MODEL_PATH=./models/Sinong1.0-8B

# 服务监听配置
HOST=0.0.0.0
PORT=8000

# GPU 配置
GPU_MEMORY_UTILIZATION=0.9
MAX_MODEL_LEN=40960
TENSOR_PARALLEL_SIZE=1

# 可选：API Key 认证
# API_KEY=your-secret-key

# 可选：模型名称
# SERVED_MODEL_NAME=Sinong1.0-8B

# 可选：数据类型
# DTYPE=bfloat16

# 可选：强制 eager 模式（调试用）
# ENFORCE_EAGER=true
